__pycache__/
*.py[cod]
*$py.class
*.so
.Python
backend/.venv/
.venv/
venv/
ENV/
.pytest_cache/
*.egg-info/
dist/
build/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
