MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/finance_dashboard
# Used only if MONGODB_URI has no database path (e.g. ends with ...mongodb.net/)
MONGODB_DB_NAME=finance_dashboard
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
# Local default 8000; Railway sets PORT automatically — you can omit PORT on Railway.
PORT=8000

# Comma-separated browser origins allowed for CORS (your Vercel URL + local dev).
# Example: http://localhost:3000,https://my-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Local HTTP: false. Production (HTTPS): true so the auth cookie can be Secure.
SECURE_COOKIES=false

SEED_ADMIN_KEY=
USERS_COLLECTION=users
TRANSACTIONS_COLLECTION=records

